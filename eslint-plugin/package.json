{
  "name": "@sethlivingston/eslint-plugin-typescript-narrows",
  "version": "1.1.1",
  "description": "Opinionated ESLint plugin for TypeScript",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sethlivingston/the-typescript-narrows.git",
    "directory": "eslint-plugin"
  },
  "homepage": "https://github.com/sethlivingston/the-typescript-narrows#readme",
  "bugs": {
    "url": "https://github.com/sethlivingston/the-typescript-narrows/issues"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "typescript",
    "opinionated",
    "lint"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0 || ^10.0.0",
    "eslint-plugin-import-x": "^4.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0",
    "minimatch": "^10.2.4",
    "typescript-eslint": "^8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  }
}
